    portrait: {fileID: 0}
  dialogues:
  - speakerIndex: 0
    dialogue: "\uB108\uBB34 \uB0A1\uC544 \uC5F4\uAE30\uB3C4 \uD798\uB4E4\uC5B4 \uBCF4\uC774\uB294
      \uC624\uB798\uB41C \uC7A5\uB871\uC774\uB2E4."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uC7A5\uB871 \uC55E\uC5D4 \uD3EC\uC2A4\uD2B8\uC787\uC774 \uC5EC\uB7EC
      \uAC1C \uBD99\uC5EC\uC838 \uC788\uC5C8\uB2E4."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "\uC74C? \uC774\uAC8C \uBB54 \uD3EC\uC2A4\uD2B8\uC787\uC774\uC9C0?"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uC5EC\uB7EC \uD3EC\uC2A4\uD2B8\uC787\uC5D4 \uC9E7\uC740 \uBB38\uAD6C\uAC00
      \uC368 \uC788\uC5C8\uB2E4. \u2018\uC544\uCE68 \uAF2D \uBA39\uAE30!\u2019, \u2018\uC190\uC8FC
      \uCC3E\uC544\uC624\uB294 \uB0A0!\u2019, \u2018\uC190\uC8FC \uC5BC\uAD74 \uC78A\uC9C0
      \uC54A\uAE30"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uB9C8\uC9C0\uB9C9 \uD3EC\uC2A4\uD2B8\uC787\uC740 \uC544\uBB34\uB7F0
      \uB9D0\uB3C4 \uC801\uD600 \uC788\uC9C0 \uC54A\uB294\uB2E4."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "\uD560\uBA38\uB2C8\u2026"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "(\uB098\uB3C4 \uBB54\uAC00 \uC801\uACE0 \uC2F6\uC5B4...)"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
