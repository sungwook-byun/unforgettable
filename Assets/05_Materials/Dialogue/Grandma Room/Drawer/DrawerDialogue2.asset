  m_Name: DrawerDialogue2
  m_EditorClassIdentifier: Assembly-CSharp::DialogueScriptable
  speakers:
  - speakerName: "\uC11C\uB78D"
    description: "\uC7A5\uB871 \uC606 \uC791\uC740 \uC11C\uB78D"
    portrait: {fileID: 21300000, guid: 5e630b85fdfd7c648b0b3fc6768d5f4d, type: 3}
  - speakerName: "\uC190\uC790"
    description: "\uC8FC\uC778\uACF5"
    portrait: {fileID: 21300000, guid: ec39ae7443554c74a9072a3c5e704272, type: 3}
  dialogues:
  - speakerIndex: 0
    dialogue: "\uB0A1\uC740 \uCC45\uB4E4\uACFC \uC5B4\uB824 \uC7A1\uB3D9\uC0AC\uB2C8\uB4E4\uC744
      \uB4A4\uB85C \uD55C \uCC44, \uC624\uB798\uB41C \uB808\uCF54\uB4DC \uD310\uC744
      \uCC3E\uC558\uB2E4."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "\uC774\uAC70\uAD6C\uB098? \uC5B4\uB77C\u2026 \uBB54\uAC00 \uBD99\uC5B4\uC788\uB124?"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uB808\uCF54\uB4DC \uD310\uC5D4 \uD3EC\uC2A4\uD2B8\uC787\uC774 \uBD99\uC5B4
      \uC788\uC5C8\uACE0 \uADF8\uACF3\uC5D4\u2026 \u2018\uC78A\uC9C0 \uB9D0 \uAC83.\u2019
      \uC774\uB77C\uACE0 \uC801\uD600 \uC788\uC5C8\uB2E4."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uB098\uBA38\uC9C0 \uAE00\uC528\uB294 \uC624\uB798\uB410\uB294\uC9C0
      \uBC88\uC838 \uC81C\uB300\uB85C \uC54C \uC218 \uC5C6\uC5C8\uB2E4."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "...\uBAA8\uB974\uACA0\uB124. \uC77C\uB2E8 \uAC00\uC838\uAC08\uAE4C."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "(\uB808\uCF54\uB4DC\uD310\uC744 \uB808\uCF54\uB4DC \uD50C\uB808\uC774\uC5B4\uC5D0
      \uAC00\uC838\uB2E4 \uB193\uC790.)"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
