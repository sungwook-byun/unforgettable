  speakers:
  - speakerName: "\uB808\uCF54\uB4DC \uD50C\uB808\uC774\uC5B4"
    description: "\uC624\uB798\uB41C \uB0A1\uC740 \uCD94\uC5B5"
    portrait: {fileID: 21300000, guid: 47f5a83d3dd814342a8fd71d525755c6, type: 3}
  - speakerName: "\uC190\uC790"
    description: "\uC8FC\uC778\uACF5"
    portrait: {fileID: 21300000, guid: ec39ae7443554c74a9072a3c5e704272, type: 3}
  - speakerName: "\uD560\uBA38\uB2C8"
    description: "\uD604\uC2E4 \uC18D \uC138\uACC4"
    portrait: {fileID: 21300000, guid: 2e4199b657881004f9f2b78f8eedcd53, type: 3}
  dialogues:
  - speakerIndex: 1
    dialogue: "\uC6D0\uB798 \uC788\uB358 \uB0A1\uC740 \uD310\uC744 \uBE7C\uACE0\u2026
      \uC774\uAC78 \uB07C\uC6B0\uBA74\u2026!"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uB808\uCF54\uB4DC \uD310\uC744 \uB123\uACE0, \uC791\uB3D9 \uC2DC\uD0A4\uC790
      \uAC10\uBBF8\uB85C\uC6B4 \uC74C\uC545 \uC18C\uB9AC\uAC00 \uD758\uB824\uB098\uC654\uB2E4."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "\uC6B0\uC640\u2026 \uC815\uB9D0\uB85C \uC88B\uC740\uB370\uC694? \uC774\uAC70
      \uB204\uAC00 \uB9CC\uB4E0 \uAC70\uC608\uC694?"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 2
    dialogue: "...\uBB58 \uB9D0\uC774\uB2C8?"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices:
    - choiceText: "\uC774 \uC74C\uC545\uC774\uC694!"
      nextIndex: 4
    - choiceText: "\uC544.. \uC544\uBB34\uAC83\uB3C4 \uC544\uB2C8\uC608\uC694."
      nextIndex: 5
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 2
  - speakerIndex: 2
    dialogue: "\uCC98\uC74C \uB4E3\uB294 \uC74C\uC545\uC778\uB370.. \uC798 \uBAA8\uB974\uACA0\uAD6C\uB098."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 1
    nextDialogueIndex: 6
    filterType: 0
  - speakerIndex: 2
    dialogue: "\uADF8\uB807\uB2C8? \uADF8\uB098\uC790\uB098 \uC74C\uC545\uC774 \uCC38
      \uC88B\uAD6C\uB098.. \uC660\uC9C0 \uB9C8\uC74C\uC774 \uD3B8\uD574\uC9C0\uB294
      \uAC70 \uAC19\uB124."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 1
    nextDialogueIndex: 6
    filterType: 0
  - speakerIndex: 1
    dialogue: ...
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 2
  - speakerIndex: 1
    dialogue: "(\uB354 \uC774\uC0C1 \uB300\uD654\uB294 \uC758\uBBF8\uC5C6\uC5B4 \uBCF4\uC778\uB2E4.)"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
