  dialogues:
  - speakerIndex: 0
    dialogue: "\uC624\uB798\uB418\uC5B4 \uBCF4\uC774\uB294 \uB0A1\uC740 \uB808\uCF54\uB4DC
      \uD50C\uB808\uC774\uC5B4\uB2E4."
