    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "\uC6B0\uC640... \uC778\uD130\uB137\uC73C\uB85C\uB9CC \uBCF4\uB358
      \uAC74\uB370 \uC544\uC9C1\uB3C4 \uC4F0\uACE0 \uACC4\uC168\uAD6C\uB098."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "\uC791\uB3D9\uC740 \uB418\uB824\uB098...?"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uAC10\uC744 \uBBFF\uC73C\uBA70, \uC774\uAC83\uC800\uAC83 \uC870\uC791\uD574
      \uBD24\uC9C0\uB9CC \uC774\uB0B4 \uC2DC\uB044\uB7EC\uC6B4 \uC74C\uB9CC \uB098\uC62C
      \uBFD0\uC774\uC5C8\uB2E4."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "\uC73C\uC544\uC544! \uC774\uAC8C \uC544\uB2CC\uB370...!"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
