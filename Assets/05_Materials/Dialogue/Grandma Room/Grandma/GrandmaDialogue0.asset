    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "\uADF8\uB7FC \uC7A0\uAE50 \uBC29 \uC880 \uAD6C\uACBD\uD574\uB3C4 \uB420\uAE4C\uC694?"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uD760... \uB531\uD788 \uB124\uAC00 \uC88B\uC544\uD560\uB9CC\uD55C
      \uAC74 \uC5C6\uC9C0\uB9CC \uC0C1\uAD00\uC5C6\uB2E8\uB2E4."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "\uAC10\uC0AC\uD569\uB2C8\uB2E4."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "(\uC77C\uB2E8 \uC9D1\uC548 \uBB3C\uAC74\uC744 \uC0B4\uD3B4\uBCF4\uBA74\uC11C
      \uC2DC\uAC04\uC744 \uB5BC\uC6B0\uC790.)"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 2
    dialogue: "\uC0C1\uD638\uC791\uC6A9 \uAC00\uB2A5\uD55C \uC624\uBE0C\uC81D\uD2B8\uB294
