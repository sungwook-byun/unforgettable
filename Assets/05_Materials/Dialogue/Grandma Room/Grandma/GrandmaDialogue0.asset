    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uC9C0\uAE08 \uC815\uC2E0\uC774 \uC5C6\uC5B4\uC11C \uC7A0\uC2DC \uAE30\uB2E4\uB824
