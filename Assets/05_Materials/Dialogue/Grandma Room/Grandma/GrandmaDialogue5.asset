    portrait: {fileID: 21300000, guid: ec39ae7443554c74a9072a3c5e704272, type: 3}
  dialogues:
  - speakerIndex: 0
    dialogue: "\uB808\uCF54\uB4DC \uBB50..? \uC544... \uCC45\uC0C1 \uC704\uC5D0 \uC788\uB294
      \uAE30\uACC4\uB97C \uB9D0\uD558\uB294\uAD6C\uB098."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uC791\uB3D9\uD558\uB294 \uBC29\uBC95\uC744 \uC54C\uB824\uB2EC\uB77C\uACE0?"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uC544, \uB9C8\uCE68 \uC798 \uB410\uAD6C\uB098. \uB108\uC5D0\uAC8C
      \uB4E4\uB824\uC8FC\uACE0 \uC2F6\uC740 \uC74C\uC545\uC774 \uC788\uB2E8\uB2E4."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "\uC74C\uC545\uC774\uC694?"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uADF8\uB798, \uC7A5\uB871 \uC606 \uC11C\uB78D\uC5D0 \uB808\uCF54\uB4DC
      \uD310\uC774 \uC788\uB2E8\uB2E4. \uADF8\uAC78 \uB123\uC5B4\uC11C \uC791\uB3D9\uC2DC\uCF1C
      \uC8FC\uACA0\uB2C8?"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "\uB124 \uC54C\uACA0\uC5B4\uC694."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "(\uC6B0\uC120, \uB808\uCF54\uB4DC \uD310\uC744 \uCC3E\uC740 \uB4A4\uC5D0
      \uB808\uCF54\uB4DC \uD50C\uB808\uC774\uC5B4\uB97C \uC0B4\uD3B4\uBCF4\uC790.)"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
