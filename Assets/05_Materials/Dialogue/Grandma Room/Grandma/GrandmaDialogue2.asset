    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "...\uD760 \uC5B4\uB514\uBCF4\uC790, \uC5B4\uC774\uCFE0 \uC9C0\uAE08
      \uBCF4\uB2C8 \uC561\uC790\uAC00 \uB5A8\uC5B4\uC9C8 \uAC83 \uAC19\uAD6C\uB098."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uBBF8\uC548\uD558\uC9C0\uB9CC \uC6B0\uC120\uC800 \uC561\uC790 \uC880
      \uC81C\uB300\uB85C \uAC78\uC5B4\uB194\uC904 \uC218 \uC788\uACA0\uB2C8?"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "\uADF8\uB7FC\uC694, \uC7A0\uC2DC\uB9CC\uC694."
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
