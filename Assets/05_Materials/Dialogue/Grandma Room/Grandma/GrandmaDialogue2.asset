  dialogues:
  - speakerIndex: 0
    dialogue: "\uC561\uC790? \uC544... \uBCBD\uC5D0 \uAC78\uB9B0 \uC800\uAC78 \uB9D0\uD558\uB294\uAD6C\uB098."
