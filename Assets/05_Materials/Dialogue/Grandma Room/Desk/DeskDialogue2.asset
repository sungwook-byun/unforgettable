    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "\uC5B4\uB77C? \uC790\uC138\uD788 \uBCF4\uB2C8\uAE4C \uC774\uAC83\uB4E4
      \uBAA8\uB450 \uC545\uBCF4\uC796\uC544?"
    typingSpeed: 0.05
    customPortrait: {fileID: 0}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
