    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 1
    dialogue: "\uC5ED\uC2DC \uC5F0\uD544\uC774 \uC788\uC5C8\uC5B4. \uC774\uAC70\uBA74
