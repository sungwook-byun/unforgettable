  speakers:
  - speakerName: "\uC190\uC790"
    description: "\uAE30\uC5B5 \uC18D \uC138\uACC4"
    portrait: {fileID: 21300000, guid: ec39ae7443554c74a9072a3c5e704272, type: 3}
  dialogues:
  - speakerIndex: 0
    dialogue: "\uC0AC\uB78C\uC758 \uD3C9\uC628\uD55C \uD638\uD761 \uC18C\uB9AC\uAC00
      \uBA87 \uCC28\uB840\uB4E4\uB838\uB2E4"
    typingSpeed: 0.05
    customPortrait: {fileID: 21300000, guid: ec39ae7443554c74a9072a3c5e704272, type: 3}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uC774 \uC77C\uAE30\uB97C \uC870\uAE08 \uB354 \uC77C\uCC0D \uC801\uC5C8\uB354\uB77C\uBA74,
      \uC870\uAE08 \uB354 \uAE30\uC5B5 \uD560 \uC218 \uC788\uB294 \uAC83\uB4E4\uC774
      \uC880\uB354 \uB9CE\uC9C0 \uC54A\uC558\uC744\uAE4C \uC0DD\uAC01\uC774 \uB4E4\uACE4\uD55C\uB2E4."
    typingSpeed: 0.05
    customPortrait: {fileID: 21300000, guid: ec39ae7443554c74a9072a3c5e704272, type: 3}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uC774 \uC810\uC740 \uB0B4\uAC8C \uD6C4\uD68C\uAC00 \uB9CE\uC774 \uB41C\uB2E4."
    typingSpeed: 0.05
    customPortrait: {fileID: 21300000, guid: ec39ae7443554c74a9072a3c5e704272, type: 3}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uC774\uC804\uC758 \uD560\uBA38\uB2C8\uC640 \uD568\uAED8 \uC788\uC5C8\uB358
      \uB0B4\uC6A9\uB4E4\uC740 \uADF8\uB9AC \uAE30\uC5B5\uC5D0 \uB0A8\uC9C0 \uC54A\uB294\uB2E4."
    typingSpeed: 0.05
    customPortrait: {fileID: 21300000, guid: ec39ae7443554c74a9072a3c5e704272, type: 3}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uD558\uC9C0\uB9CC \uAE30\uC5B5\uC774 \uC78A\uC5B4\uC9C0\uB294 \uC640\uC911\uC5D0\uB3C4
      \uD560\uBA38\uB2C8\uC758 \uAC10\uC815"
    typingSpeed: 0.05
    customPortrait: {fileID: 21300000, guid: ec39ae7443554c74a9072a3c5e704272, type: 3}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uADF8\uB9AC\uACE0 \uD560\uBA38\uB2C8\uAC00 \uC0AC\uB791\uD588\uB358
      \uAC83\uB4E4\uC744 \uB4E3\uACE0 \uBCF4\uBA70"
    typingSpeed: 0.05
    customPortrait: {fileID: 21300000, guid: ec39ae7443554c74a9072a3c5e704272, type: 3}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uD568\uAED8 \uC788\uC5B4\uC90C\uC774\uB77C\uB294 \uAC83\uC774 \uD560\uBA38\uB2C8\uC758
      \uC9C0\uC6CC\uC838 \uAC00\uB294 \uC138\uC0C1 \uC18D\uC5D0\uC11C \uC704\uB85C\uAC00
      \uB418\uC5B4"
    typingSpeed: 0.05
    customPortrait: {fileID: 21300000, guid: ec39ae7443554c74a9072a3c5e704272, type: 3}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uD560\uBA38\uB2C8\uAC00 \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uB9CC\uB4E4\uC5C8\uB358
      \uC800\uACE0\uB9AC \uCC98\uB7FC"
    typingSpeed: 0.05
    customPortrait: {fileID: 21300000, guid: ec39ae7443554c74a9072a3c5e704272, type: 3}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
  - speakerIndex: 0
    dialogue: "\uC544\uB984\uB2E4\uC6B4 \uC2E4\uD0C0\uB798\uAC00 \uC774\uC5B4\uC9C0\uB294
      \uADF8 \uAE30\uC5B5\uC744 \uB09C \uC78A\uC744 \uC218 \uC5C6\uC744 \uAC83\uC774\uB2E4."
    typingSpeed: 0.05
    customPortrait: {fileID: 21300000, guid: ec39ae7443554c74a9072a3c5e704272, type: 3}
    choices: []
    isChoiceOnly: 0
    nextDialogueIndex: -1
    filterType: 0
